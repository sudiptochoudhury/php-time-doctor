#!/usr/bin/env php
<?php

error_reporting(E_ALL & ~E_DEPRECATED & ~E_USER_DEPRECATED);

set_error_handler(static function ($errno, $errstr) {
    if ($errno === E_DEPRECATED || $errno === E_USER_DEPRECATED) {
        return true;
    }
    $warnings = ['Trying to access array offset on false', 'foreach() argument must be of type array|object'];

    if ($errno === E_WARNING) {
        $suppress = array_reduce($warnings, function ($carry, $warning) use ($errstr) {
            return $carry || strpos($errstr, $warning) !== false;
        }, false);
        if ($suppress) {
            return true;
        }
    }
    return false; // defer to PHP's normal handling for anything else
});


/*
|--------------------------------------------------------------------------
| Register The Auto Loader
|--------------------------------------------------------------------------
|
| Composer provides a convenient, automatically generated class loader
| for our application. We just need to utilize it! We'll require it
| into the script here so that we do not have to worry about the
| loading of any our classes "manually". Feels great to relax.
|
*/

require_once __DIR__ . '/src/TimeDoctor/Support/autoloader.php';

use SudiptoChoudhury\TimeDoctor\Support\Cli;

Cli::$rootPath = __DIR__ . '/';

try {

    $cli = new Cli();
    $cli->run();

} catch(\Exception $ex) {
    echo $ex->getMessage();
}

exit(0);
